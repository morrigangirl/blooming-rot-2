  "notes": [
    {
      "_id": "Note861490fddbf1",
      "entryId": null,
      "pageId": null,
      "x": 1610,
      "y": 760,
      "elevation": 0,
      "sort": 0,
      "texture": {
        "src": "icons/svg/eye.svg",
        "anchorX": 0.5,
        "anchorY": 0.5,
        "offsetX": 0,
        "offsetY": 0,
        "fit": "fill",
        "scaleX": 1,
        "scaleY": 1,
        "rotation": 0,
        "tint": "#ffffff",
        "alphaThreshold": 0
      },
      "iconSize": 40,
      "fontSize": 32,
      "fontFamily": "Signika",
      "textAnchor": 1,
      "textColor": "#ffffff",
      "text": "Start — Sparrow's corner (head of Wick Lane). She launches the instant the party moves to take her.",
      "global": false,
      "flags": {},
      "_key": "!scenes.notes!BR2SceneSprwLftwk.Note861490fddbf1"
    },
    {
      "_id": "Noted65c1bb0cb76",
      "entryId": null,
      "pageId": null,
      "x": 1610,
      "y": 1180,
      "elevation": 0,
      "sort": 0,
      "texture": {
        "src": "icons/svg/regen.svg",
        "anchorX": 0.5,
        "anchorY": 0.5,
        "offsetX": 0,
        "offsetY": 0,
        "fit": "fill",
        "scaleX": 1,
        "scaleY": 1,
        "rotation": 0,
        "tint": "#ffffff",
        "alphaThreshold": 0
      },
      "iconSize": 40,
      "fontSize": 32,
      "fontFamily": "Signika",
      "textAnchor": 1,
      "textColor": "#ffffff",
      "text": "Reach 1 — Cloth Market crowd. DC 13: Athletics (shove), Acrobatics (vault), Intimidation/Persuasion (\"Make way!\"), Insight/Investigation (cut the corner). Sparrow uses Nimble Bolt to open the gap.",
      "global": false,
      "flags": {},
      "_key": "!scenes.notes!BR2SceneSprwLftwk.Noted65c1bb0cb76"
    },
    {
      "_id": "Note3313a2eff4ac",
      "entryId": null,
      "pageId": null,
      "x": 1300,
      "y": 1380,
      "elevation": 0,
      "sort": 0,
      "texture": {
        "src": "icons/svg/scroll.svg",
        "anchorX": 0.5,
        "anchorY": 0.5,
        "offsetX": 0,
        "offsetY": 0,
        "fit": "fill",
        "scaleX": 1,
        "scaleY": 1,
        "rotation": 0,
        "tint": "#ffffff",
        "alphaThreshold": 0
      },
      "iconSize": 40,
      "fontSize": 32,
      "fontFamily": "Signika",
      "textAnchor": 1,
      "textColor": "#ffffff",
      "text": "Reach 2 — Market wall & Loft Steps. FOLD DROPS HERE. Athletics/Acrobatics DC 15 to clear the wall. A pursuer can snatch the oilcloth fold (costs their action) or mark the spot and grab it after.",
      "global": false,
      "flags": {},
      "_key": "!scenes.notes!BR2SceneSprwLftwk.Note3313a2eff4ac"
    },
    {
      "_id": "Note44cd7774aa04",
      "entryId": null,
      "pageId": null,
      "x": 1580,
      "y": 1770,
      "elevation": 0,
      "sort": 0,
      "texture": {
        "src": "icons/svg/run.svg",
        "anchorX": 0.5,
        "anchorY": 0.5,
        "offsetX": 0,
        "offsetY": 0,
        "fit": "fill",
        "scaleX": 1,
        "scaleY": 1,
        "rotation": 0,
        "tint": "#ffffff",
        "alphaThreshold": 0
      },
      "iconSize": 40,
      "fontSize": 32,
      "fontFamily": "Signika",
      "textAnchor": 1,
      "textColor": "#ffffff",
      "text": "Reach 3 — Tanners' Cut. Sparrow upends a fleece-barrow. DC 15: Acrobatics/Dexterity (vault), Athletics (bull through), Survival/streetwise (parallel cut). A fumble costs a round untangling wool.",
      "global": false,
      "flags": {},
      "_key": "!scenes.notes!BR2SceneSprwLftwk.Note44cd7774aa04"
    },
    {
      "_id": "Note3c12479434dc",
      "entryId": null,
      "pageId": null,
      "x": 1720,
      "y": 2070,
      "elevation": 0,
      "sort": 0,
      "texture": {
        "src": "icons/svg/door-exit.svg",
        "anchorX": 0.5,
        "anchorY": 0.5,
        "offsetX": 0,
        "offsetY": 0,
        "fit": "fill",
        "scaleX": 1,
        "scaleY": 1,
        "rotation": 0,
        "tint": "#ffffff",
        "alphaThreshold": 0
      },
      "iconSize": 40,
      "fontSize": 32,
      "fontFamily": "Signika",
      "textAnchor": 1,
      "textColor": "#ffffff",
      "text": "Reach 4 — The culvert (escape). Half-open grate at the waterline + flat skiff in the reeds. Sparrow escapes UNLESS the party has already driven Lead to 0 AND has a real way to follow (flying, Small, readied grapple, hold person, misty step, water-walking).",
      "global": false,
      "flags": {},
      "_key": "!scenes.notes!BR2SceneSprwLftwk.Note3c12479434dc"
    },
    {
      "_id": "Note98b52e2ac7a1",
      "entryId": null,
      "pageId": null,
      "x": 2200,
      "y": 1400,
      "elevation": 0,
      "sort": 0,
      "texture": {
        "src": "icons/svg/clockwork.svg",
        "anchorX": 0.5,
        "anchorY": 0.5,
        "offsetX": 0,
        "offsetY": 0,
        "fit": "fill",
        "scaleX": 1,
        "scaleY": 1,
        "rotation": 0,
        "tint": "#ffffff",
        "alphaThreshold": 0
      },
      "iconSize": 40,
      "fontSize": 32,
      "fontFamily": "Signika",
      "textAnchor": 1,
      "textColor": "#ffffff",
      "text": "Lead tracker — start at 2. Party drives down with success, Sparrow drives up. She escapes when the route runs out. Keep to 3–4 rounds; never let one bad roll end it. THE CLUE IS NOT THE CAPTURE — the fold drops at Reach 2 regardless.",
      "global": false,
      "flags": {},
      "_key": "!scenes.notes!BR2SceneSprwLftwk.Note98b52e2ac7a1"
    }
